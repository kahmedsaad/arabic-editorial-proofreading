AI_CLIENT=mock
USE_GCP=false
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
STORAGE_BUCKET=
ENABLE_LETTER_VARIANT_WARNINGS=false
# Punctuation findings: off | strict | full (default strict for precision)
PUNCTUATION_POLICY=strict
DEMO_AUTH_REQUIRED=true
PUBLIC_PASSWORD=demo
ADMIN_PASSWORD=302@Labs
# Comma-separated; use * on Cloud Run demo if needed
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Optional override (Cloud Run demo uses /tmp/app.db)
# SQLITE_PATH=/tmp/app.db

# Dataset storage: local (default, no GCP needed) or gcs
DATA_BACKEND=local
LOCAL_DATA_DIR=./data/local
GCS_DATA_BUCKET=arabic-proofreading-data-ooredoo-499510
GCS_DATA_PREFIX=
DATA_CACHE_DIR=./data/cache
DATA_CACHE_ENABLED=true
