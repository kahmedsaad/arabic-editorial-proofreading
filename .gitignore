# Byte-compiled
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env
dist/
build/
*.egg-info/
.coverage
htmlcov/
frontend/node_modules/
frontend/dist/
frontend/.tanstack/
data/ui_reference/

.gcp-gemini-sa.json
*.iam.json

# Hidden benchmark_v2 gold (scorer-only; never feed the engine)
benchmark_v2/private/gold/
benchmark_v2/private/manifest.json
benchmark_v2/results/*
!benchmark_v2/results/.gitkeep
_tmp_benchmark_v2/

# Local / private / cached datasets (not GitHub)
data/local/
data/downloads/
data/cache/
data/private/
data/editor_feedback/
data/before_after/

# Evaluation secrets and private gold
benchmark_v2/private/
benchmark_v2/**/private_gold*
**/*private_gold*
**/*hidden_gold*

# Large frozen eval dumps (keep docs + templates tracked)
data/evaluation/runs/

# Downloaded / compressed dataset archives
*.jsonl.gz
*.parquet
*.arrow
*.csv.gz
